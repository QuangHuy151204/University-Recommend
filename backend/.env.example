# Copy file này thành `backend/.env` và điền giá trị thực.
# KHÔNG commit file `.env` (đã trong .gitignore mặc định của NestJS).

# ─── PostgreSQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=university_recommend

# Schema: mặc định dùng migration (an toàn). Chỉ bật synchronize tạm khi DB trống lần đầu.
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

# ─── Auth (JWT) ───────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Admin (seed khi khởi động + đăng nhập /admin/login) ─
# Bắt buộc đặt ADMIN_PASSWORD trước deploy. Đổi mật khẩu mạnh trên prod.
ADMIN_SEED_ENABLED=true
ADMIN_USERNAME=Admin
ADMIN_EMAIL=admin@system.local
ADMIN_PASSWORD=your_strong_admin_password
# Cookie JWT (httpOnly)
JWT_COOKIE_MAX_AGE_MS=604800000

# Global rate limit (fallback cho toàn API)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120

# ─── Email (xác nhận đăng ký + quên mật khẩu) ───────────
# Dev: để trống SMTP_HOST — mã 6 số in ra console backend (MAIL_DEV_LOG=true).
# Prod: cấu hình SMTP (Gmail App Password, SendGrid, Mailtrap, …).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=University Recommend
MAIL_DEV_LOG=true

# ─── HTTP ─────────────────────────────────────────────────
PORT=3001
# Thêm origin frontend nếu không dùng localhost:3000 (phân tách bằng dấu phẩy)
# CORS_ORIGINS=http://192.168.1.10:3000

# ─── Ollama (chatbot LLM) ─────────────────────────────────
# Bật mặc định để chatbot dùng LLM cho intent classify + diễn đạt câu trả lời.
# Yêu cầu: cài Ollama (https://ollama.com) + `ollama pull <model>`.
# Khi Ollama không chạy, ChatbotService tự fallback rule-based — bot vẫn dùng được,
# nhưng mỗi câu sẽ có độ trễ ~ OLLAMA_TIMEOUT_MS chờ timeout.
# Đặt OLLAMA_ENABLED=false để tắt và tránh độ trễ này khi chưa cài Ollama.
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
# qwen2.5:3b (1.9 GB) — nhẹ, vừa GPU 6 GB, tiếng Việt khá. Đổi thành llama3.1, gemma3:1b,
# llama3.2:3b… tuỳ máy. Sau khi đổi nhớ `ollama pull <model>`.
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_MS=20000
