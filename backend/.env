# Ollama (chatbot LLM local)
# Yêu cầu: cài Ollama (https://ollama.com) + `ollama pull qwen2.5:3b` trước khi backend khởi động.
# Khi Ollama không chạy, ChatbotService tự fallback rule-based (có delay ~ OLLAMA_TIMEOUT_MS mỗi câu).
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_MS=20000


DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true