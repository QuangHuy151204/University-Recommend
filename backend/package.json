{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:regression": "jest --testPathPatterns=\"(intent-regression|duplicate-cleanup|major-normalization|major-name-match|university-cutoff-filter|university-filter-evaluator|chat-session-context|recommendation-tier|recommendations-regression|chatbot-intent-pipeline|chatbot-guardrails|chatbot-follow-up-e2e|interest-synonyms|score-trend|university-extract)\\.spec\\.ts$\"",
    "test:university-filter-audit": "ts-node -r tsconfig-paths/register scripts/run-university-filter-audit.ts",
    "test:university-filter-50": "ts-node -r tsconfig-paths/register scripts/run-university-filter-50.ts",
    "test:university-filter-50-popular": "ts-node -r tsconfig-paths/register scripts/run-university-filter-50-popular.ts",
    "benchmark:ollama-e2e": "ts-node -r tsconfig-paths/register scripts/benchmark-ollama-e2e.ts",
    "import:excel": "ts-node -r tsconfig-paths/register src/import-excel.ts",
    "import:excel:merge": "ts-node -r tsconfig-paths/register src/import-excel.ts -- --merge",
    "import:tuition": "ts-node -r tsconfig-paths/register src/import-tuition-excel.ts -- --patch-master",
    "generate:intent-corpus": "ts-node -r tsconfig-paths/register scripts/generate-intent-corpus.ts",
    "report:data-gaps": "ts-node -r tsconfig-paths/register scripts/report-data-gaps.ts",
    "export:uncategorized-majors": "ts-node -r tsconfig-paths/register scripts/export-uncategorized-majors.ts",
    "benchmark:ollama-intent": "ts-node -r tsconfig-paths/register scripts/benchmark-ollama-intent.ts",
    "sync:major-classification": "ts-node -r tsconfig-paths/register scripts/sync-major-classification.ts",
    "backfill:major-codes": "ts-node -r tsconfig-paths/register scripts/backfill-major-codes.ts",
    "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/data-source.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d src/data-source.ts",
    "migration:show": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:show -d src/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "nodemailer": "^8.0.8",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
